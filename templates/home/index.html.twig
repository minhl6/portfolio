{% extends 'base.html.twig' %}

{% block title %}Minh Le — Mechanical Engineering Student{% endblock %}

{% block body %}

<section class="hero" id="home">
    <div class="container hero-inner">
        <div class="hero-text fade-in">
            <p class="hero-eyebrow">Hi, I'm</p>
            <h1>Minh Le</h1>
            <p class="hero-subtitle">a Mechanical Engineering student designing, building, and testing things that move.</p>
            <p class="hero-description">
                Currently in my second year, working toward joining a UBC design team and looking for an engineering
                internship. I like turning ideas into CAD models, then into parts you can actually hold.
            </p>
            <div class="hero-actions">
                <a href="#projects" class="btn btn-primary">View Projects</a>
                <a href="/resume.pdf" class="btn btn-secondary">Resume</a>
                <a href="https://linkedin.com/in/your-profile" target="_blank" rel="noopener" class="btn btn-secondary">LinkedIn</a>
            </div>
        </div>
        <div class="hero-photo fade-in">
            <img src="https://picsum.photos/seed/minh-le-profile/640/640" alt="Portrait of Minh Le" width="640" height="640">
        </div>
    </div>
    <a href="#about" class="scroll-cue" aria-label="Scroll down">
        <span></span>
    </a>
</section>

<section class="about" id="about">
    <div class="container">
        <h2 class="section-heading fade-in">About</h2>
        <div class="about-grid fade-in">
            <p class="about-text">
                Replace this paragraph with your own story: where you're studying, what got you interested in
                mechanical engineering, and what kind of problems you like working on (e.g. mechanisms, robotics,
                manufacturing, vehicle dynamics). Keep it to a few sentences — this is the elevator-pitch version of you.
            </p>
            <ul class="skills-list">
                <li>SolidWorks / Fusion 360</li>
                <li>ANSYS &amp; FEA</li>
                <li>3D Printing &amp; Laser Cutting</li>
                <li>Arduino / Embedded Basics</li>
                <li>Manufacturing &amp; Machining</li>
                <li>Technical Drawing (GD&amp;T)</li>
            </ul>
        </div>
    </div>
</section>

<section class="projects" id="projects">
    <div class="container">
        <h2 class="section-heading fade-in">Projects</h2>

        <div class="project-filters fade-in" role="group" aria-label="Filter projects by category">
            <button class="filter-btn is-active" data-filter="all" aria-pressed="true">All</button>
            <button class="filter-btn" data-filter="personal" aria-pressed="false">Personal Projects</button>
            <button class="filter-btn" data-filter="school" aria-pressed="false">School Projects</button>
        </div>

        <div class="projects-grid">
            {% for slug, project in projects %}
                <article class="project-card fade-in" data-category="{{ project.category }}">
                    <a href="{{ path('app_project_show', { slug: slug }) }}" class="project-card-link">
                        <div class="project-card-image">
                            <img src="{{ project.image }}" alt="{{ project.title }}" loading="lazy">
                            <span class="project-card-badge">{{ project.category == 'school' ? 'School' : 'Personal' }}</span>
                        </div>
                        <div class="project-card-body">
                            <h3>{{ project.title }}</h3>
                            <p>{{ project.tagline }}</p>
                            <span class="learn-more">Learn more →</span>
                        </div>
                    </a>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="contact" id="contact">
    <div class="container fade-in">
        <h2 class="section-heading">Get in touch</h2>
        <p class="contact-text">
            I'm currently applying to UBC design teams and looking for internship opportunities. Feel free to reach out.
        </p>
        <div class="contact-links">
            <a href="mailto:benny.minh@gmail.com" class="btn btn-primary">benny.minh@gmail.com</a>
            <a href="https://linkedin.com/in/your-profile" target="_blank" rel="noopener" class="btn btn-secondary">LinkedIn</a>
            <a href="https://github.com/your-profile" target="_blank" rel="noopener" class="btn btn-secondary">GitHub</a>
        </div>
    </div>
</section>

{% endblock %}
